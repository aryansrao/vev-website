---
const year = new Date().getFullYear();
---
<footer>
  <div class="wrap">
    <div class="foot">
      <div class="about">
        <div class="brand"><img src="/assets/vev-wordmark-dark.png" alt="Vev" class="brand-mark" style="height:32px" /></div>
        <p>A from-scratch privacy browser where fingerprint resistance, threat blocking, and on-device AI are defaults — not paid add-ons.</p>
      </div>
      <div class="col">
        <h4>Product</h4>
        <a href="/huma-ai">Huma AI</a>
        <a href="/privacy-security">Privacy &amp; security</a>
        <a href="/incognito">Private windows</a>
        <a href="/extensions">Extensions</a>
        <a href="/community-feed">Community feed</a>
      </div>
      <div class="col">
        <h4>Learn</h4>
        <a href="/guide">User guide</a>
        <a href="/docs">Documentation</a>
        <a href="/faq">FAQ</a>
        <a href="/download">Download</a>
      </div>
      <div class="col">
        <h4>Open source</h4>
        <a href="https://github.com/aryansrao/vev">Vev on GitHub</a>
        <a href="https://github.com/aryansrao/community-phishing-feed">Community feed repo</a>
      </div>
    </div>
    <div class="foot-bottom">
      <span>© {year} Vev. Free and open.</span>
      <span>Built on Chromium Embedded Framework &amp; Tauri.</span>
    </div>
  </div>
</footer>
