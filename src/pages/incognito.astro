const jsonld = [{"@context": "https://schema.org", "@type": "WebPage", "name": "Private windows in Vev"}, {"@context": "https://schema.org", "@type": "FAQPage", "mainEntity": [{"@type": "Question", "name": "How is a Vev private window different from Chrome's incognito?", "acceptedAnswer": {"@type": "Answer", "text": "Two ways. First, it's always a separate window \u2014 private and normal browsing never share a window, so you can't accidentally mix them. Second, it removes WebRTC entirely and forces fingerprint resistance for the whole private session, which ordinary incognito modes don't do."}}, {"@type": "Question", "name": "Does anything get saved in private mode?", "acceptedAnswer": {"@type": "Answer", "text": "No. Private windows share one in-memory session with no disk cache. History, cookies, and cache all vanish when the last private window closes."}}, {"@type": "Question", "name": "Do my private settings carry across tabs and windows?", "acceptedAnswer": {"@type": "Answer", "text": "Yes. The switches on the private home page \u2014 block WebRTC, force fingerprint resistance, shields \u2014 apply to every tab in every private window for the whole session, not just the tab you set them in."}}, {"@type": "Question", "name": "How do I open a private window?", "acceptedAnswer": {"@type": "Answer", "text": "Press Cmd/Ctrl+Shift+N, or choose New private window from the menu or command palette. You'll get a separate window with an indigo-tinted chrome so you always know which mode you're in."}}]}];
---
<Base title="Private windows in Vev \u2014 real isolation, zero WebRTC leaks" description="Vev private browsing always opens a separate window with its own in-memory session and session-wide privacy switches: block WebRTC, force fingerprint resistance, and shield every page. Nothing touches disk." jsonld={jsonld}>
<section class="page-head"><div class="wrap"><span class="eyebrow" data-reveal data-hero>Private windows</span><h1 data-reveal data-hero>Incognito that actually isolates</h1><p data-reveal data-hero>Private browsing is a separate window with its own session and its own switches — never mixed with your normal tabs.</p></div></section><section class="rule"><div class="wrap">
 <div class="sec-head" data-reveal><span class="eyebrow">How it works</span><h2>One private session, everywhere</h2></div>
 <div class="rows"><div class="row" data-reveal><h3>Separate by design</h3><div class="rtxt">Opening a private window gives you a distinct window — indigo-tinted so it's unmistakable. Every tab in it, and every other private window you open, shares one ephemeral in-memory session. Your normal tabs are never involved.</div></div><div class="row" data-reveal><h3>Nothing hits disk</h3><div class="rtxt">There is no disk cache and no persisted cookies or history for private windows. When the last one closes, the entire session is discarded.</div></div><div class="row" data-reveal><h3>Session-wide switches</h3><div class="rtxt">The private home page has three switches — block WebRTC, fingerprint resistance, and ad/tracker shields — and they hold for the whole private run across every tab and window, not just where you flipped them.</div></div><div class="row" data-reveal><h3>Verified isolation</h3><div class="rtxt">In a private window, <code>RTCPeerConnection</code>, <code>RTCDataChannel</code>, and media-device enumeration are all removed, and the device profile reads as a fixed Windows/Intel machine instead of your real hardware.</div></div></div>
 </div></section>
 <section class="rule"><div class="wrap narrow">
 <div class="sec-head" data-reveal><span class="eyebrow">Using it</span><h2>Open and tune a private session</h2></div>
 <ol class="steps" data-reveal>
   <li>Press <kbd>⌘⇧N</kbd> (macOS) or <kbd>Ctrl+Shift+N</kbd>, or pick <strong>New private window</strong> from the menu.</li>
   <li>On the private home page, set the three privacy switches to taste. The defaults are the strongest.</li>
   <li>Browse. Everything you open in this window — and any other private window — stays in the same throwaway session.</li>
   <li>Close the last private window to wipe the session. Nothing is left behind.</li>
 </ol>
 </div></section>
 <section class="rule"><div class="wrap narrow"><div class="sec-head" data-reveal><span class="eyebrow">FAQ</span><h2>Questions about private windows</h2></div><div class="faq" data-reveal><details><summary>How is a Vev private window different from Chrome&#x27;s incognito?</summary><p>Two ways. First, it&#x27;s always a separate window — private and normal browsing never share a window, so you can&#x27;t accidentally mix them. Second, it removes WebRTC entirely and forces fingerprint resistance for the whole private session, which ordinary incognito modes don&#x27;t do.</p></details><details><summary>Does anything get saved in private mode?</summary><p>No. Private windows share one in-memory session with no disk cache. History, cookies, and cache all vanish when the last private window closes.</p></details><details><summary>Do my private settings carry across tabs and windows?</summary><p>Yes. The switches on the private home page — block WebRTC, force fingerprint resistance, shields — apply to every tab in every private window for the whole session, not just the tab you set them in.</p></details><details><summary>How do I open a private window?</summary><p>Press Cmd/Ctrl+Shift+N, or choose New private window from the menu or command palette. You&#x27;ll get a separate window with an indigo-tinted chrome so you always know which mode you&#x27;re in.</p></details></div></div></section>
</Base>
