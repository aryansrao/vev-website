# Copy to Vercel project env vars. Site-verification tokens go into the
# corresponding <meta> tags (see index.html) or Vercel Domains verification.
GOOGLE_SITE_VERIFICATION=your-google-search-console-token
BING_SITE_VERIFICATION=your-bing-webmaster-token

# Community phishing report API (api/report.js). A fine-grained GitHub token
# with contents:write on the feed repo, used to commit reports server-side.
GITHUB_TOKEN=github_pat_xxx
FEED_REPO=aryansrao/community-phishing-feed
